/**
 * WARP & PCAP Analyzer v2 — Wrangler Configuration
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "warp-pcap-analyzer",
	"main": "src/index.js",
	"compatibility_date": "2025-01-01",

	/**
	 * Observability (logging, tracing)
	 */
	"observability": {
		"enabled": true
	},

	/**
	 * Workers AI Binding
	 * Provides access to Llama 4 Scout, Llama 3.3, DeepSeek R1
	 */
	"ai": {
		"binding": "AI"
	},

	/**
	 * Workers KV — Session Storage
	 * Stores analysis sessions, decoded packets, AI results.
	 * Create the namespace with:
	 *   npx wrangler kv namespace create SESSIONS
	 * Then paste the ID below.
	 */
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "5cdad6d61afd4742af8344776b51b434"
		}
	],

	/**
	 * Environment Variables
	 * CF_ACCESS_TEAM_DOMAIN: Your Cloudflare Access team domain (e.g., "myteam" or "myteam.cloudflareaccess.com")
	 * CF_ACCESS_AUD: Application Audience (AUD) tag from Access Application config
	 *
	 * If both are unset, auth is bypassed (dev mode).
	 */
	"vars": {
		"CF_ACCESS_TEAM_DOMAIN": "",
		"CF_ACCESS_AUD": ""
	},

	/**
	 * Custom Domain Configuration
	 */
	"routes": [
		{
			"pattern": "warp-analyzer.dtg-lab.net",
			"custom_domain": true
		}
	],

	/**
	 * Smart Placement — route requests to the nearest data centre with AI GPUs
	 */
	"placement": {
		"mode": "smart"
	}

	/**
	 * Limits — increase for large PCAP processing
	 * "limits": { "cpu_ms": 30000 }
	 */
}
