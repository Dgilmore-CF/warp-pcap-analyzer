/**
 * WARP & PCAP Analyzer v2 — Wrangler Configuration
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 *
 * SECURITY NOTE — What's in this file:
 *   • KV namespace IDs and custom domain routes are deployment identifiers.
 *     They are NOT credentials. They appear in public Cloudflare examples.
 *   • Sensitive config (CF_ACCESS_TEAM_DOMAIN, CF_ACCESS_AUD) is stored as
 *     encrypted Worker secrets, NOT as vars in this file. Set them via:
 *
 *       npx wrangler secret put CF_ACCESS_TEAM_DOMAIN
 *       npx wrangler secret put CF_ACCESS_AUD
 *
 *   • Deployment credentials (CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID)
 *     live in GitHub repository secrets and never touch this file.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "warp-pcap-analyzer",
	"main": "src/index.js",
	"compatibility_date": "2025-01-01",

	/**
	 * Observability (logging, tracing)
	 */
	"observability": {
		"enabled": true
	},

	/**
	 * Workers AI Binding — Llama 4 Scout, Llama 3.3, DeepSeek R1.
	 */
	"ai": {
		"binding": "AI"
	},

	/**
	 * Workers KV — Session Storage
	 * The `id` below is a public identifier (not a credential). To deploy
	 * this project to a different Cloudflare account, create your own
	 * namespace with `npx wrangler kv namespace create SESSIONS` and
	 * replace the ID here.
	 */
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "5cdad6d61afd4742af8344776b51b434"
		}
	],

	/**
	 * Custom Domain — public DNS record, not sensitive.
	 * For a new deployment, change this to your own hostname.
	 */
	"routes": [
		{
			"pattern": "warp-analyzer.dtg-lab.net",
			"custom_domain": true
		}
	],

	/**
	 * Smart Placement — route requests to the nearest data centre with AI GPUs
	 */
	"placement": {
		"mode": "smart"
	}

	/**
	 * CONFIGURATION NOT IN THIS FILE (set via `wrangler secret put`):
	 *   CF_ACCESS_TEAM_DOMAIN  — your Cloudflare Access team domain
	 *   CF_ACCESS_AUD          — Application Audience tag from Access app config
	 *
	 * When both secrets are missing, the Worker runs in dev-bypass mode
	 * (see src/auth.js) and all requests are treated as user dev@localhost.
	 *
	 * Limits — enterprise plans can increase the CPU limit:
	 *   "limits": { "cpu_ms": 30000 }
	 */
}
